# Signal — Environment Configuration (Example)
# Copy this to .env and fill in your values

# Slack — Get these from https://api.slack.com/apps -> Your App -> Settings
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret

# AI Provider (OpenAI-compatible — works with Groq, OpenAI, Grok, etc.)
# Groq:   https://api.groq.com/openai/v1   (models: llama-3.3-70b-versatile, mixtral-8x7b-32768)
# OpenAI: https://api.openai.com/v1         (models: gpt-4o-mini, gpt-4o)
# Grok:   https://api.x.ai/v1               (models: grok-2-1212)
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=signal
DB_PASSWORD=signal
DB_NAME=signal
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# MCP Server
MCP_SERVER_URL=http://localhost:3001/sse
MCP_SERVER_TIMEOUT=30s

# App
APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=info
APP_FRONTEND_URL=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=Signal
